# ============================================================
# AirPak Express — Environment variables (Vercel project settings)
# Copy each key into Vercel → Settings → Environment Variables
# ============================================================

# ---- Supabase (already used by the existing site) ----
VITE_SUPABASE_URL=https://zygoqqsgzhgpvlpttfbk.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# ---- Supabase SERVICE ROLE (server-side only, NEVER exposed to browser) ----
# Used by /api/* serverless functions to bypass RLS.
SUPABASE_URL=https://zygoqqsgzhgpvlpttfbk.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# ---- WhatsApp Business Bridge ----
# Which BSP to use: twilio | 360dialog | meta
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM=+18053956873

# Twilio
WHATSAPP_ACCOUNT_ID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_TOKEN=your-twilio-auth-token

# 360dialog / Meta Cloud API
# WHATSAPP_API_KEY=your-360dialog-or-meta-key
# WHATSAPP_PHONE_ID=123456789012345   # Meta only

# Shared secret between Supabase trigger and /api/whatsapp/send.
# Set the same value in `app.bp_bridge_secret` Postgres config.
WHATSAPP_BRIDGE_SECRET=replace-with-long-random-string
WHATSAPP_VERIFY_TOKEN=replace-with-verify-token

# URL the Supabase trigger posts to (set in Supabase SQL editor):
# ALTER DATABASE postgres SET app.bp_bridge_url   TO 'https://YOUR-DOMAIN.vercel.app/api/whatsapp/send';
# ALTER DATABASE postgres SET app.bp_bridge_secret TO '<WHATSAPP_BRIDGE_SECRET>';